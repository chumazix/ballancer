{
  "title": "System Dashboard",
  "panels": [
    {
      "title": "Статус балансировщиков",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"nginx\"}", "legendFormat": "{{instance}}" }]
    },
    {
      "title": "Доступность бэкенд-нод",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"node\", instance=~\"172.20.0.(20|21):9100\"}", "legendFormat": "{{instance}}" }]
    },
    {
      "title": "Состояние VIP-адреса",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"nginx\", instance=\"172.20.0.10:9113\"}", "legendFormat": "VIP активен" }]
    },
    {
      "title": "Нагрузка на ноды (CPU)",
      "type": "timeseries",
      "targets": [{ "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Нагрузка на ноды (RAM)",
      "type": "timeseries",
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Сетевой трафик (RX)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[5m])", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "title": "Сетевой трафик (TX)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[5m])", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "title": "Активные соединения Nginx",
      "type": "timeseries",
      "targets": [{ "expr": "nginx_connections_active", "legendFormat": "{{instance}}" }]
    }
  ],
  "schemaVersion": 16,
  "version": 0
}
