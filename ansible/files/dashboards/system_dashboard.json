{
  "title": "System Dashboard",
  "tags": ["nginx", "loadbalancer", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "panels": [
    {
      "id": 1,
      "title": "Статус балансировщиков",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"nginx\", instance=\"172.20.0.10:9113\"}", "legendFormat": "lb1", "refId": "A" },
        { "expr": "up{job=\"nginx\", instance=\"172.20.0.11:9113\"}", "legendFormat": "lb2", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.5 } ] },
          "mappings": [ { "type": "value", "value": "1", "text": "Активен" }, { "type": "value", "value": "0", "text": "Недоступен" } ]
        }
      }
    },
    {
      "id": 2,
      "title": "Доступность бэкенд-нод",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "up{job=\"node\", instance=\"172.20.0.20:9100\"}", "legendFormat": "backend1", "refId": "A" },
        { "expr": "up{job=\"node\", instance=\"172.20.0.21:9100\"}", "legendFormat": "backend2", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.5 } ] },
          "mappings": [ { "type": "value", "value": "1", "text": "Доступен" }, { "type": "value", "value": "0", "text": "Недоступен" } ]
        }
      }
    },
    {
      "id": 3,
      "title": "Состояние VIP-адреса (косвенное)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "up{job=\"nginx\", instance=\"172.20.0.10:9113\"}", "legendFormat": "VIP статус", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.5 } ] },
          "mappings": [ { "type": "value", "value": "1", "text": "Активен (предположительно на lb1)" }, { "type": "value", "value": "0", "text": "Неактивен" } ]
        }
      },
      "description": "VIP активен, если работает nginx-экспортер на lb1 (косвенная метрика)"
    },
    {
      "id": 4,
      "title": "Нагрузка на ноды (CPU)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 5,
      "title": "Нагрузка на ноды (RAM)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 6,
      "title": "Сетевой трафик (RX)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[5m])", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "id": 7,
      "title": "Сетевой трафик (TX)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[5m])", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "id": 8,
      "title": "HTTP статус-коды (общее количество запросов)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        { "expr": "rate(nginx_http_requests_total[5m])", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "description": "Примечание: разбивка по статус-кодам требует установки nginx-module-vts. В текущей конфигурации доступна только общая статистика."
    },
    {
      "id": 9,
      "title": "Активные соединения Nginx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "expr": "nginx_connections_active", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    }
  ]
}
